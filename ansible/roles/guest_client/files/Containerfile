FROM registry.access.redhat.com/ubi9/ubi-minimal:latest

LABEL description="Guest Client — 정상 사용자 TCP 접속 테스터"

RUN microdnf install -y python3 python3-pip && microdnf clean all

WORKDIR /app

COPY requirements.txt .
RUN pip3 install --no-cache-dir -r requirements.txt

COPY guest_client.py .

ENV NODE1_IP=192.168.100.7
ENV NODE2_IP=192.168.100.8
ENV TARGET_PORT=8080
ENV API_PORT=7070
ENV TEST_INTERVAL=5.0
ENV CONNECT_TIMEOUT=2.0

EXPOSE 7070

CMD ["python3", "/app/guest_client.py"]
